    "device_id": "",
    "api_base_url": "https://api.acinfinity.com",
    "status_path": "/v1/devices/{device_id}",
    "power_path": "/v1/devices/{device_id}/power",
    "speed_path": "/v1/devices/{device_id}/speed",
    "mock_mode": "true"
